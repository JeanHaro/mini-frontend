{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "types": ["reflect-metadata"],
        "lib": ["ES2020", "DOM"],
        "strict": true,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "moduleResolution": "bundler"
    },
    "include": ["src/**/*"]
}